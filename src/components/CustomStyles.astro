---
import '@fontsource-variable/inter';
---

<style is:inline>
  /* FinTech Association brand palette
     - Brand Maroon   #8C2D2D
     - Brand Mustard  #F0B323
     - Deep Navy      #1A2639
     - Muted Slate    #94A3B8
     All text/background combinations below pass WCAG AA. */

  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Primary = Brand Maroon (CTAs, headings, key brand) */
    --aw-color-primary: #8c2d2d;
    /* Secondary = darker maroon; safe as text on white and as btn-primary hover */
    --aw-color-secondary: #6b2020;
    /* Accent = Brand Mustard (badges, borders, highlights — not text on white) */
    --aw-color-accent: #f0b323;

    --aw-color-text-heading: #8c2d2d;
    --aw-color-text-default: #1a2639;
    --aw-color-text-muted: #4b5563;
    --aw-color-text-page: #1a2639;
    --aw-color-bg-page: #ffffff;
    --aw-color-bg-page-dark: #1a2639;
    --aw-color-border: #e5e7eb;

    /* Text color that sits on a primary-colored surface (button fill). */
    --aw-color-on-primary: #ffffff;

    ::selection {
      background-color: #f0b323;
      color: #1a2639;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* In dark mode primary interactive = Brand Mustard (maroon fails contrast on navy). */
    --aw-color-primary: #f0b323;
    --aw-color-secondary: #d99a0f;
    --aw-color-accent: #f0b323;

    --aw-color-text-heading: #ffffff;
    --aw-color-text-default: #94a3b8;
    --aw-color-text-muted: #94a3b8;
    --aw-color-text-page: #94a3b8;
    --aw-color-bg-page: #1a2639;
    --aw-color-border: #2d3a52;

    /* White text on mustard fails AA; use deep navy instead. */
    --aw-color-on-primary: #1a2639;

    ::selection {
      background-color: #f0b323;
      color: #1a2639;
    }
  }
</style>
